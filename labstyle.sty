%* ---------------------------------- ТЕКСТ ---------------------------------- %

% ----------------------------------- Текст ---------------------------------- %
\linespread{1.2}

% ---------------------------------- Формула --------------------------------- %
\AtBeginDocument{
    \setlength{\abovedisplayskip}{3px}
    \setlength{\belowdisplayskip}{3px}
    \setlength{\abovedisplayshortskip}{1px}
    \setlength{\belowdisplayshortskip}{1px}
}


% ---------------------------------- Сноски ---------------------------------- %
\tcbuselibrary{skins, breakable}

\newtcolorbox{note}{
    enhanced,
    colback=gray!10,
    boxrule=0pt,
    arc=0pt,
    outer arc=0pt,
    left=4pt,
    right=3pt,
    top=3pt,
    bottom=3pt,
    before skip=8pt,
    after skip=8pt,
    overlay={
        \draw[gray!50, line width=3pt]
        (frame.south west) -- (frame.north west);
        \draw[gray!50, line width=1pt]
        ([xshift=3pt]frame.south west) -- ([xshift=3pt]frame.north west);
    }
}


%* --------------------------- НАСТРОЙКИ СТРАНИЦЫ ---------------------------- %

% ----------------------------- Размеры и отступы ---------------------------- %
\geometry{
    a4paper,
    left=2cm,
    right=1cm,
    top=1cm,
    bottom=1cm,
    footskip=0.8cm,
    includehead,
    includefoot,
} 

% -------------------------------- Колонтитулы ------------------------------- %

\def\labauthors{...}%                   значение по умолчанию
\fancyhead[RO,LE]{\labauthors}
\fancyhead[LO,RE]{\shortlabtheme}


%* ---------------------------- ЗАГОЛОВКИ/РАЗДЕЛЫ ---------------------------- %
\makeatletter
\renewcommand{\section}{\@startsection{section}{1}{\z@}
    {-2.5ex \@plus -0.8ex \@minus -.2ex}
    {1.8ex \@plus.2ex}
    {\Large\bfseries\centering\MakeUppercase}}
\renewcommand{\thesection}{\Roman{section}.}

\renewcommand{\subsection}{\@startsection{subsection}{2}{\z@}
    {-2.5ex \@plus -0.8ex \@minus -.2ex}
    {1.2ex \@plus .2ex}
    {\large\bfseries}}
\renewcommand{\thesubsection}{\arabic{subsection}.}

\renewcommand{\subsubsection}{\@startsection{subsubsection}{3}{\z@}
    {-2.5ex \@plus -0.8ex \@minus -.2ex}
    {1.0ex \@plus .2ex}
    {\normalsize\bfseries}}
\renewcommand{\thesubsubsection}{\arabic{subsection}.\arabic{subsubsection}}
\makeatother

% --------------------------- Заголовок Приложения --------------------------- %
\newcounter{appsection}
\renewcommand{\theappsection}{\arabic{appsection}}

\newcommand{\appendixsection}[1]{
	\refstepcounter{appsection}
	\vspace{1em}
	\noindent{\largeПриложение \theappsection. #1}
	\par\nopagebreak
	\addcontentsline{toc}{subsection}{Приложение \theappsection. #1}  % Добавляем в оглавление
	\label{app:#1}  % Автоматическая метка (можно заменить на ручные \label)
}

%* ------------------------------ ПЕРЕЧИСЛЕНИЯ ------------------------------- %

% --------------------------------- Enumerate -------------------------------- %
% При использовании алфавита для перечисления будет использоваться кириллица
\setlist[enumerate,2]{label=\asbuk*)}

\makeatletter
\AddEnumerateCounter{\asbuk}{\russian@alph}{щ}
\makeatother

% Настройки отступов
\setlist[enumerate]{
    noitemsep,
    topsep=0.1em,    % уменьшено с 0.2em
    parsep=0pt,
    partopsep=0pt,
    itemsep=0.1em,   % уменьшено с 0.2em
}

% ---------------------------------- Itemize --------------------------------- %
% Настройки отступов
\setlist[itemize]{
    noitemsep,
    topsep=0.1em,    % уменьшено с 0.2em
    parsep=0pt,
    partopsep=0pt,
    itemsep=0.1em,   % уменьшено с 0.2em
}

%* --------------------- ИЗОБРАЖЕНИЯ/ФОТОГРАФИИ/ГРАФИКА ---------------------- %

% ------------------------ Настройки подписей рисунков ----------------------- %
\captionsetup[figure]{
    labelsep=period,            % Разделение текста описания и метки
    name={Рис.},
    justification=centering,    % Выравнивание текста
    font={small},               % Параметры шрифта описания
    labelfont={bf},             % Параметры шрифта метки
    skip=4pt,                   % Расстояние между подписью и изображением
    belowskip=2pt,              % Отступ под подписью
    position=above,             % Подпись под изображением
}

%* ------------------------------- МАТЕМАТИКА -------------------------------- %

% -------------------------- Математические операции ------------------------- %
\DeclareMathOperator{\re}{\operatorname{Re}}
\DeclareMathOperator{\im}{\operatorname{Im}}
\DeclareMathOperator\Div{\operatorname{div}}
\DeclareMathOperator\Rot{\operatorname{rot}}
\DeclareMathOperator\Grad{\operatorname{grad}}

% ------------------------------- Буквы/Символы ------------------------------ %
\DeclareMathOperator{\Epsilon}{\mathcal{E}}
\DeclareMathOperator{\A}{\mathcal{A}}
\DeclareMathOperator{\R}{\mathc al{R}}

%* --------------------------------- ССЫЛКИ ---------------------------------- %

% -------------------------------- URL-ссылки -------------------------------- %
\hypersetup{
    colorlinks=true,
    linkcolor=black,
    urlcolor=black,
    citecolor=black,
    pdfencoding=auto,
    psdextra=true
}

% ----------------------- Ссылки на элементы документа ----------------------- %
\crefname{figure}{рис.}{рис.}
\Crefname{figure}{Рис.}{Рис.}
\crefname{table}{табл.}{табл.}
\Crefname{table}{Табл.}{Табл.}
\crefname{appsection}{прил.}{прил.}
\Crefname{appsection}{Прил.}{Прил.}
\crefname{listing}{лист.}{лист.}
\Crefname{listing}{Лист.}{Лист.}
\crefname{equation}{}{(}
\crefformat{equation}{(#2#1#3)}
\crefrangelabelformat{equation}{(#3#1#4--#5#2#6)}
\crefmultiformat{equation}{(#2#1#3)}{ и~(#2#1#3)}{, (#2#1#3)}{ и~(#2#1#3)}

